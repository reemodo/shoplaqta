generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  orders    Order[]
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Decimal
  category    String
  condition   String?
  stock       Int         @default(1)
  imageUrl    String?
  createdAt   DateTime    @default(now())
  images      String[]
  orderItems  OrderItem[]
}

model Order {
  id            String      @id @default(uuid())
  customerName  String
  customerPhone String
  totalAmount   Decimal
  status        String      @default("PENDING")
  city          String
  street        String
  locationUrl   String?
  notes         String?
  userId        String?
  pickupSlotId  String?
  createdAt     DateTime    @default(now())
  pickupSlot    PickupSlot? @relation(fields: [pickupSlotId], references: [id])
  user          User?       @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model PickupSlot {
  id           String   @id @default(uuid())
  locationName String
  startTime    DateTime
  endTime      DateTime
  maxOrders    Int
  bookedCount  Int      @default(0)
  orders       Order[]
}
